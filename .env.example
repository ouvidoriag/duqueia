# ==============================================================================
#                      CONFIGURACAO DE AMBIENTE - DUQUE IA
# ==============================================================================

# ---- GEMINI API (Google AI Studio / Vertex AI) --------------------------------
# Chaves válidas: aceita chaves tradicionais do AI Studio ("AIzaSy...") e tokens do Vertex AI ("AQ.Ab8RN...")
GEMINI_API_KEYS=AIzaSy_chave1_aqui,AQ.Ab8RN_token_aqui

# Camada de triagem inteligente (triage layer)
USE_TRIAGE_LAYER=true

# Modelo de geracao de texto
GEMINI_MODEL=gemini-2.5-flash

# Modelo de embedding (3072 dimensoes)
# Opcoes disponiveis: gemini-embedding-2 | gemini-embedding-2-preview | gemini-embedding-001
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# ---- BANCO DE DADOS SUPABASE (PGVector) --------------------------------------
# Para uso em producao com busca vetorial real
SUPABASE_URL=https://sua-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ---- CONFIGURACOES DO SISTEMA ------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=info

# ---- OPENAI (Alternativo) ----------------------------------------------------
# Caso queira usar OpenAI em vez do Gemini
OPENAI_API_KEY=sua-chave-openai-aqui
